# Copy this file to `.env` and fill in your own values.
# .env is gitignored — never commit real credentials.

# AMap Web Service key (高德 Web 服务).
# Used for the JS API map render *and* the REST /v3/bus/linename calls
# the loader makes. Get one at https://console.amap.com/dev/key/app
M3D_AMAP_KEY=

# Optional: security code (安全密钥) for keys that require it.
M3D_AMAP_SECURITY_CODE=
