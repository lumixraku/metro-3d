{
  "name": "metro-3d",
  "version": "0.1.0",
  "description": "A real-time 3D digital map of the Shenzhen Metro, inspired by mini-tokyo-3d.",
  "main": "dist/metro-3d.js",
  "module": "dist/metro-3d.esm.js",
  "style": "dist/metro-3d.css",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "dev": "run-p watch serve",
    "serve": "http-server . -c-1 -p 8080 -o /"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "http-server": "^14.1.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "rollup": "^4.57.1",
    "rollup-plugin-postcss": "^4.0.2"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "author": "luonan@pikaia.ai",
  "license": "MIT"
}
